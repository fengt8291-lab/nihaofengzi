---
import WorkCover from '@/components/work/WorkCover.astro';
import { getWorkHref, type WorkEntry } from '@/lib/work';

interface Props {
  entry: WorkEntry;
  priority?: boolean;
  presentation?: 'featured' | 'standard';
}

const { entry, priority = false, presentation = 'standard' } = Astro.props;
const href = getWorkHref(entry);
const isExternal = entry.data.detailMode === 'external';
const isArchive = entry.data.detailMode === 'archive';
const hasCover = !isArchive && Boolean(entry.data.coverImage || entry.data.coverVariant);
const metadata = [
  { label: '状态', value: entry.data.cardStatus ?? entry.data.status },
  entry.data.role ? { label: '我的角色', value: entry.data.role } : undefined,
].filter((item): item is { label: string; value: string } => Boolean(item));
---

<article
  aria-label={entry.data.title}
  class:list={[
    'work-card-shell',
    isArchive ? 'work-card-shell--archive' : `work-card-shell--${presentation}`,
  ]}
>
  <div class:list={['work-card', { 'work-card--has-cover': hasCover }]}>
    {
      hasCover && (
        <WorkCover
          coverImage={entry.data.coverImage}
          coverAlt={entry.data.coverAlt}
          coverVariant={entry.data.coverVariant}
          priority={priority}
        />
      )
    }

    <p class="work-card__type">{entry.data.type}</p>

    <div class="work-card__content">
      <h3 class="work-card__title">{entry.data.title}</h3>
      <p class="work-card__summary">{entry.data.summary}</p>
    </div>

    <dl class="work-card__meta">
      {
        metadata.map((item) => (
          <div>
            {item.label === '状态' ? <dt aria-label="状态"></dt> : <dt>{item.label}</dt>}
            <dd>{item.value}</dd>
          </div>
        ))
      }
    </dl>

    {
      href && (
        <a
          class="work-card__link"
          href={href}
          target={isExternal ? '_blank' : undefined}
          rel={isExternal ? 'noreferrer' : undefined}
        >
          {isExternal ? '访问项目' : '查看项目'}
          <span aria-hidden="true">{isExternal ? '↗' : '→'}</span>
        </a>
      )
    }
  </div>
</article>

<style>
  .work-card-shell {
    min-width: 0;
    box-shadow: none;
  }

  .work-card-shell--featured {
    background: transparent;
  }

  .work-card-shell--standard {
    padding: var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-card-background);
  }

  .work-card-shell--archive {
    padding-block: var(--space-5);
    border-top: 1px solid var(--color-border-strong);
    border-radius: 0;
    background: transparent;
  }

  .work-card {
    display: flex;
    flex-direction: column;
  }

  .work-card-shell--featured .work-card {
    min-height: 100%;
  }

  .work-card--has-cover .work-card__type {
    margin-top: var(--space-5);
  }

  .work-card__type {
    max-width: 22rem;
    margin: 0;
    color: var(--color-growth);
    font-size: var(--type-caption-size);
    font-weight: var(--type-caption-weight);
    letter-spacing: 0.06em;
    line-height: var(--type-caption-leading);
  }

  .work-card__content {
    margin-top: var(--space-5);
  }

  .work-card__title {
    margin: 0;
    font-size: var(--type-card-title-size);
    font-weight: var(--type-card-title-weight);
    letter-spacing: var(--type-card-title-tracking);
    line-height: var(--type-card-title-leading);
    line-break: strict;
    text-wrap: pretty;
  }

  .work-card-shell--archive .work-card__title {
    color: var(--color-text-primary);
    font-size: var(--type-body-large-size);
    font-weight: 560;
    letter-spacing: var(--type-body-large-tracking);
    line-height: var(--type-body-large-leading);
  }

  .work-card__summary {
    margin: var(--space-4) 0 0;
    color: var(--color-text-secondary);
    font-size: var(--type-body-size);
    font-weight: var(--type-body-weight);
    letter-spacing: var(--type-body-tracking);
    line-height: var(--type-body-leading);
    line-break: strict;
    text-wrap: pretty;
  }

  .work-card__meta {
    display: grid;
    gap: var(--space-4);
    padding-top: var(--space-5);
    margin: var(--space-5) 0 0;
    border-top: 1px solid var(--color-border);
  }

  .work-card-shell--featured .work-card__meta {
    margin-top: auto;
  }

  .work-card-shell--archive .work-card__meta {
    padding-top: 0;
    margin-top: var(--space-4);
    border-top: 0;
  }

  .work-card__meta div {
    min-width: 0;
  }

  .work-card__meta dt {
    color: var(--color-text-tertiary);
    font-size: var(--type-caption-size);
    font-weight: var(--type-caption-weight);
    letter-spacing: var(--type-caption-tracking);
    line-height: var(--type-caption-leading);
  }

  .work-card__meta dd {
    margin: var(--space-1) 0 0;
    font-size: var(--type-meta-size);
    font-weight: var(--type-meta-weight);
    letter-spacing: var(--type-meta-tracking);
    line-height: var(--type-meta-leading);
    line-break: strict;
    text-wrap: pretty;
  }

  .work-card__link {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-5);
    color: var(--color-accent);
    font-size: var(--type-meta-size);
    line-height: var(--type-meta-leading);
    font-weight: 600;
    text-decoration: none;
  }

  .work-card__link span {
    transition: transform var(--duration-fast) var(--ease-standard);
  }

  .work-card__link:hover span {
    transform: translateX(0.2rem);
  }

  @media (min-width: 48rem) {
    .work-card-shell--standard {
      padding: var(--space-6);
    }

    .work-card__meta {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .work-card-shell--archive .work-card__meta {
      grid-template-columns: minmax(0, 16rem) minmax(0, 1fr);
    }
  }
</style>
