---
import { PROFILE } from '@/data/profile';

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<div class:list={['education-summary', { 'education-summary--compact': compact }]}> 
  <div>
    <p class="education-summary__school">{PROFILE.education.school}</p>
    <p>{PROFILE.education.college}</p>
  </div>
  <dl>
    <div>
      <dt>专业</dt>
      <dd>{PROFILE.education.major}</dd>
    </div>
    <div>
      <dt>阶段</dt>
      <dd>{PROFILE.education.stage}</dd>
    </div>
    <div>
      <dt>时间</dt>
      <dd>{PROFILE.education.period}</dd>
    </div>
  </dl>
</div>

<style>
  .education-summary {
    display: grid;
    gap: var(--space-6);
    padding: var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-card-background);
  }

  .education-summary p {
    margin: 0;
    color: var(--color-text-secondary);
  }

  .education-summary__school {
    color: var(--color-text-primary) !important;
    font-size: 1.375rem;
    font-weight: 620;
    letter-spacing: -0.025em;
  }

  .education-summary dl {
    display: grid;
    gap: var(--space-4);
    margin: 0;
  }

  .education-summary dl div {
    display: grid;
    gap: var(--space-1);
  }

  .education-summary dt {
    color: var(--color-text-tertiary);
    font-size: 0.75rem;
  }

  .education-summary dd {
    margin: 0;
    color: var(--color-text-primary);
    line-height: 1.65;
  }

  @media (min-width: 48rem) {
    .education-summary:not(.education-summary--compact) {
      grid-template-columns: minmax(13rem, 0.7fr) minmax(0, 1.3fr);
    }

    .education-summary:not(.education-summary--compact) dl {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
