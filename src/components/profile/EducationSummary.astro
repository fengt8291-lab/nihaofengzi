---
import { getSiteContent } from '@/lib/site-content';

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
const education = (await getSiteContent()).identity.education;
---

<div class:list={['education-summary', { 'education-summary--compact': compact }]}> 
  <div>
    <p class="education-summary__school">{education.school}</p>
    <p>{education.college}</p>
  </div>
  <dl>
    <div>
      <dt>专业</dt>
      <dd>{education.major}</dd>
    </div>
    <div>
      <dt>阶段</dt>
      <dd>{education.stage}</dd>
    </div>
    <div>
      <dt>时间</dt>
      <dd>{education.period}</dd>
    </div>
  </dl>
</div>

<style>
  .education-summary {
    display: grid;
    gap: var(--space-6);
    padding-block: var(--space-6);
    border-block: 1px solid var(--color-border-strong);
  }

  .education-summary p {
    margin: 0;
    color: var(--color-text-secondary);
  }

  .education-summary__school {
    color: var(--color-text-primary) !important;
    font-size: var(--type-card-title-size);
    font-weight: var(--type-card-title-weight);
    letter-spacing: var(--type-card-title-tracking);
    line-height: var(--type-card-title-leading);
    line-break: strict;
    text-wrap: pretty;
  }

  .education-summary dl {
    display: grid;
    gap: var(--space-4);
    margin: 0;
  }

  .education-summary dl div {
    display: grid;
    gap: var(--space-1);
  }

  .education-summary dt {
    color: var(--color-text-tertiary);
    font-size: var(--type-caption-size);
    font-weight: var(--type-caption-weight);
    letter-spacing: var(--type-caption-tracking);
    line-height: var(--type-caption-leading);
  }

  .education-summary dd {
    margin: 0;
    color: var(--color-text-primary);
    font-size: var(--type-meta-size);
    font-weight: var(--type-meta-weight);
    letter-spacing: var(--type-meta-tracking);
    line-height: var(--type-meta-leading);
    overflow-wrap: anywhere;
  }

  @media (min-width: 48rem) {
    .education-summary:not(.education-summary--compact) {
      grid-template-columns: minmax(13rem, 0.7fr) minmax(0, 1.3fr);
    }

    .education-summary:not(.education-summary--compact) dl {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
