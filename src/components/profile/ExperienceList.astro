---
import type { ProfileExperience } from '@/lib/site-content';

interface Props {
  experiences: readonly ProfileExperience[];
  compact?: boolean;
}

const { experiences, compact = false } = Astro.props;
---

<ol class:list={['experience-list', { 'experience-list--compact': compact }]}> 
  {
    experiences.map((experience) => (
      <li>
        <article class="experience-item">
          <header>
            <div>
              <h3>{experience.title}</h3>
              <p>{experience.role}</p>
            </div>
            <p class="experience-item__period">{experience.period}</p>
          </header>

          <p class="experience-item__summary">{experience.summary}</p>

          {!compact && (
            <ul class="experience-item__responsibilities">
              {experience.responsibilities.map((responsibility) => (
                <li>{responsibility}</li>
              ))}
            </ul>
          )}

          {experience.boundary && <p class="experience-item__boundary">{experience.boundary}</p>}
        </article>
      </li>
    ))
  }
</ol>

<style>
  .experience-list {
    display: grid;
    gap: 0;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--color-border-strong);
    list-style: none;
  }

  .experience-list--compact {
    width: 100%;
    max-width: var(--layout-editorial-width);
  }

  .experience-list > li {
    border-bottom: 1px solid var(--color-border);
  }

  .experience-item {
    padding-block: var(--space-6);
  }

  .experience-item header {
    display: grid;
    gap: var(--space-3);
  }

  .experience-item h3,
  .experience-item header p {
    margin: 0;
  }

  .experience-item h3 {
    font-size: var(--type-card-title-size);
    font-weight: var(--type-card-title-weight);
    letter-spacing: var(--type-card-title-tracking);
    line-height: var(--type-card-title-leading);
    line-break: strict;
    text-wrap: pretty;
  }

  .experience-item header div > p,
  .experience-item__period {
    margin-top: var(--space-2) !important;
    color: var(--color-text-tertiary);
    font-size: var(--type-meta-size);
    font-weight: var(--type-meta-weight);
    letter-spacing: var(--type-meta-tracking);
    line-height: var(--type-meta-leading);
  }

  .experience-item__summary {
    max-width: var(--measure-body);
    margin: var(--space-5) 0 0;
    color: var(--color-text-secondary);
    font-size: var(--type-body-size);
    line-height: var(--type-body-leading);
    line-break: strict;
    text-wrap: pretty;
  }

  .experience-item__responsibilities {
    padding-left: 1.15rem;
    margin: var(--space-5) 0 0;
    color: var(--color-text-secondary);
    font-size: var(--type-body-size);
    line-height: var(--type-body-leading);
    line-break: strict;
    text-wrap: pretty;
  }

  .experience-item__responsibilities li + li {
    margin-top: var(--space-2);
  }

  .experience-item__boundary {
    padding-top: var(--space-4);
    margin: var(--space-5) 0 0;
    border-top: 1px solid var(--color-border);
    color: var(--color-text-tertiary);
    font-size: var(--type-meta-size);
    font-weight: var(--type-meta-weight);
    letter-spacing: var(--type-meta-tracking);
    line-height: var(--type-meta-leading);
    line-break: strict;
    text-wrap: pretty;
  }

  @media (min-width: 48rem) {
    .experience-item header {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: start;
    }

    .experience-item__period {
      margin-top: 0 !important;
      text-align: right;
    }
  }
</style>
