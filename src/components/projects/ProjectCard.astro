---
import type { CollectionEntry } from 'astro:content';

import Card from '@/components/ui/Card.astro';
import Tag from '@/components/ui/Tag.astro';

interface Props {
  project: CollectionEntry<'projects'>['data'];
  index: number;
}

const { project, index } = Astro.props;
---

<Card as="article" padding="large" ariaLabel={project.title}>
  <div class="project-card">
    <header class="project-card__header">
      <span class="project-card__index" aria-hidden="true">{String(index).padStart(2, '0')}</span>
      <Tag tone="accent">{project.status}</Tag>
    </header>

    <div class="project-card__body">
      <p class="project-card__category">{project.category}</p>
      <h3 class="project-card__title">{project.title}</h3>
      <p class="project-card__summary">{project.summary}</p>
    </div>

    <dl class="project-card__meta">
      <div>
        <dt>我的角色</dt>
        <dd>{project.role}</dd>
      </div>
    </dl>

    <details class="project-card__details">
      <summary>
        <span>查看详情</span>
        <span class="project-card__details-icon" aria-hidden="true">＋</span>
      </summary>
      <div class="project-card__details-content">
        <slot />
      </div>
    </details>
  </div>
</Card>

<style>
  .project-card {
    display: flex;
    min-height: 100%;
    flex-direction: column;
  }

  .project-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .project-card__index {
    color: var(--color-text-tertiary);
    font-size: 0.75rem;
    font-weight: 650;
    letter-spacing: 0.12em;
  }

  .project-card__body {
    margin-top: var(--space-7);
  }

  .project-card__category {
    margin: 0;
    color: var(--color-growth);
    font-size: 0.75rem;
    font-weight: 650;
    letter-spacing: 0.1em;
  }

  .project-card__title {
    margin: var(--space-2) 0 0;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 620;
    letter-spacing: -0.045em;
    line-height: 1.08;
  }

  .project-card__summary {
    max-width: 42rem;
    margin: var(--space-4) 0 0;
    color: var(--color-text-secondary);
    font-size: 1rem;
    line-height: 1.75;
  }

  .project-card__meta {
    padding-top: var(--space-6);
    margin: auto 0 0;
  }

  .project-card__meta div {
    display: grid;
    gap: var(--space-1);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .project-card__meta dt {
    color: var(--color-text-tertiary);
    font-size: 0.75rem;
  }

  .project-card__meta dd {
    margin: 0;
    color: var(--color-text-primary);
    font-size: 0.9375rem;
  }

  .project-card__details {
    margin-top: var(--space-5);
    border-top: 1px solid var(--color-border);
  }

  .project-card__details summary {
    display: flex;
    min-height: 3.5rem;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    color: var(--color-accent);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
  }

  .project-card__details summary::-webkit-details-marker {
    display: none;
  }

  .project-card__details-icon {
    color: var(--color-text-tertiary);
    font-size: 1.125rem;
    line-height: 1;
    transition: transform var(--duration-fast) var(--ease-standard);
  }

  .project-card__details[open] .project-card__details-icon {
    transform: rotate(45deg);
  }

  .project-card__details-content {
    padding: 0 0 var(--space-2);
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
    line-height: 1.75;
  }

  .project-card__details-content :global(p) {
    margin: 0;
  }
</style>
