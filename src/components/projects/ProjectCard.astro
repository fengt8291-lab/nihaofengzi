---
import type { CollectionEntry } from 'astro:content';

import Card from '@/components/ui/Card.astro';

interface Props {
  project: CollectionEntry<'projects'>['data'];
  index: number;
  featured?: boolean;
}

const { project, index, featured = false } = Astro.props;
---

<Card as="article" padding="medium" ariaLabel={project.title} class="project-card-shell">
  <div class:list={['project-card', { 'project-card--featured': featured }]}>
    <header class="project-card__header">
      <span class="project-card__index" aria-hidden="true">{String(index).padStart(2, '0')}</span>
      <span class="project-card__status">
        <span class="project-card__status-mark" aria-hidden="true"></span>
        {project.status}
      </span>
    </header>

    <div class="project-card__body">
      <div class="project-card__identity">
        <p class="project-card__category">{project.category}</p>
        <h3 class="project-card__title">{project.title}</h3>
      </div>
      <p class="project-card__summary">{project.summary}</p>
    </div>

    <div class="project-card__footer">
      <dl class="project-card__meta">
        <div>
          <dt>我的角色</dt>
          <dd>{project.role}</dd>
        </div>
      </dl>

      <details class="project-card__details">
        <summary>
          <span>查看详情</span>
          <span class="project-card__details-icon" aria-hidden="true">＋</span>
        </summary>
        <div class="project-card__details-content">
          <slot />
        </div>
      </details>
    </div>
  </div>
</Card>

<style>
  :global(.project-card-shell) {
    border-radius: var(--radius-md);
    box-shadow: none;
  }

  .project-card {
    display: flex;
    min-height: 100%;
    flex-direction: column;
  }

  .project-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .project-card__index,
  .project-card__status {
    color: var(--color-text-tertiary);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
  }

  .project-card__status {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .project-card__status-mark {
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 50%;
    background: var(--color-growth);
  }

  .project-card__body {
    display: grid;
    gap: var(--space-5);
    margin-top: var(--space-6);
  }

  .project-card__category {
    margin: 0;
    color: var(--color-growth);
    font-size: 0.75rem;
    font-weight: 650;
    letter-spacing: 0.1em;
  }

  .project-card__title {
    margin: var(--space-2) 0 0;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 620;
    letter-spacing: -0.045em;
    line-height: 1.08;
  }

  .project-card__summary {
    max-width: 42rem;
    margin: 0;
    color: var(--color-text-secondary);
    font-size: 1rem;
    line-height: 1.75;
  }

  .project-card__footer {
    margin-top: auto;
    padding-top: var(--space-6);
  }

  .project-card__meta {
    margin: 0;
  }

  .project-card__meta div {
    display: grid;
    gap: var(--space-1);
    padding-block: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .project-card__meta dt {
    color: var(--color-text-tertiary);
    font-size: 0.75rem;
  }

  .project-card__meta dd {
    margin: 0;
    color: var(--color-text-primary);
    font-size: 0.9375rem;
  }

  .project-card__details {
    border-top: 1px solid var(--color-border);
  }

  .project-card__details summary {
    display: flex;
    min-height: 3.5rem;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    color: var(--color-accent);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
  }

  .project-card__details summary::-webkit-details-marker {
    display: none;
  }

  .project-card__details-icon {
    color: var(--color-text-tertiary);
    font-size: 1.125rem;
    line-height: 1;
    transition: transform var(--duration-fast) var(--ease-standard);
  }

  .project-card__details[open] .project-card__details-icon {
    transform: rotate(45deg);
  }

  .project-card__details-content {
    padding: 0 0 var(--space-3);
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
    line-height: 1.75;
  }

  .project-card__details-content :global(p) {
    margin: 0;
  }

  @media (min-width: 48rem) {
    .project-card--featured .project-card__body {
      grid-template-columns: minmax(14rem, 0.72fr) minmax(20rem, 1.28fr);
      align-items: end;
      gap: var(--space-8);
    }

    .project-card--featured .project-card__title {
      font-size: clamp(2.75rem, 5vw, 4rem);
    }
  }
</style>
