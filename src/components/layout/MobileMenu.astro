---
import type { NavigationItem } from '@/types/site';

interface Props {
  items: readonly NavigationItem[];
}

const { items } = Astro.props;
const menuId = 'mobile-primary-navigation';
---

<div class="mobile-menu" data-mobile-menu>
  <button
    class="mobile-menu__toggle"
    type="button"
    aria-expanded="false"
    aria-controls={menuId}
    aria-label="打开主导航"
    data-mobile-menu-toggle
  >
    <span class="mobile-menu__icon" aria-hidden="true">
      <span></span>
      <span></span>
    </span>
  </button>

  <nav
    id={menuId}
    class="mobile-menu__panel"
    aria-label="移动端主导航"
    data-mobile-menu-panel
  >
    <ul class="mobile-menu__list">
      {
        items.map((item) => (
          <li>
            <a class="mobile-menu__link" href={item.href} data-mobile-menu-link>
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</div>

<script>
  const menuRoots = document.querySelectorAll<HTMLElement>('[data-mobile-menu]');

  menuRoots.forEach((root) => {
    const toggle = root.querySelector<HTMLButtonElement>('[data-mobile-menu-toggle]');
    const panel = root.querySelector<HTMLElement>('[data-mobile-menu-panel]');
    const links = root.querySelectorAll<HTMLAnchorElement>('[data-mobile-menu-link]');

    if (!toggle || !panel) return;

    const desktopQuery = window.matchMedia('(min-width: 48rem)');

    const setOpen = (open: boolean, returnFocus = false) => {
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? '关闭主导航' : '打开主导航');
      root.toggleAttribute('data-open', open);
      panel.hidden = !open;

      if (returnFocus) toggle.focus();
    };

    root.setAttribute('data-menu-ready', '');
    setOpen(false);

    toggle.addEventListener('click', () => {
      setOpen(toggle.getAttribute('aria-expanded') !== 'true');
    });

    links.forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
        setOpen(false, true);
      }
    });

    document.addEventListener('pointerdown', (event) => {
      if (
        toggle.getAttribute('aria-expanded') === 'true' &&
        event.target instanceof Node &&
        !root.contains(event.target)
      ) {
        setOpen(false);
      }
    });

    desktopQuery.addEventListener('change', (event) => {
      if (event.matches) setOpen(false);
    });
  });
</script>

<style>
  .mobile-menu {
    position: relative;
  }

  .mobile-menu__toggle {
    display: none;
    width: 2.75rem;
    height: 2.75rem;
    align-items: center;
    justify-content: center;
    padding: 0;
    border: 0;
    border-radius: var(--radius-pill);
    background: transparent;
    color: var(--color-text-primary);
    cursor: pointer;
    transition: background-color var(--duration-fast) var(--ease-standard);
  }

  .mobile-menu__toggle:hover {
    background: var(--color-accent-soft);
  }

  .mobile-menu__icon {
    position: relative;
    display: block;
    width: 1rem;
    height: 0.75rem;
  }

  .mobile-menu__icon span {
    position: absolute;
    left: 0;
    width: 100%;
    height: 1px;
    background: currentColor;
    transform-origin: center;
    transition:
      top var(--duration-fast) var(--ease-standard),
      transform var(--duration-fast) var(--ease-standard);
  }

  .mobile-menu__icon span:first-child {
    top: 0.125rem;
  }

  .mobile-menu__icon span:last-child {
    top: 0.625rem;
  }

  .mobile-menu[data-open] .mobile-menu__icon span:first-child {
    top: 0.375rem;
    transform: rotate(45deg);
  }

  .mobile-menu[data-open] .mobile-menu__icon span:last-child {
    top: 0.375rem;
    transform: rotate(-45deg);
  }

  .mobile-menu__panel {
    position: absolute;
    top: calc(100% + var(--space-2));
    right: 0;
    width: min(18rem, calc(100vw - (var(--container-gutter) * 2)));
    padding: var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-card-background);
    box-shadow: var(--shadow-card);
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity var(--duration-base) var(--ease-standard),
      transform var(--duration-base) var(--ease-standard);
  }

  .mobile-menu__panel[hidden] {
    display: none;
  }

  .mobile-menu__list {
    display: grid;
    gap: var(--space-1);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .mobile-menu__link {
    display: flex;
    min-height: 2.75rem;
    align-items: center;
    padding-inline: var(--space-4);
    border-radius: var(--radius-sm);
    color: var(--color-text-primary);
    font-size: 1rem;
    font-weight: 520;
    text-decoration: none;
    transition:
      background-color var(--duration-fast) var(--ease-standard),
      color var(--duration-fast) var(--ease-standard);
  }

  .mobile-menu__link:hover {
    background: var(--color-accent-soft);
    color: var(--color-accent);
  }

  @media (max-width: 47.999rem) {
    .mobile-menu[data-menu-ready] .mobile-menu__toggle {
      display: inline-flex;
    }

    .mobile-menu:not([data-menu-ready]) .mobile-menu__panel {
      position: fixed;
      top: var(--header-height);
      right: var(--container-gutter);
    }
  }

  @media (min-width: 48rem) {
    .mobile-menu {
      display: none;
    }
  }
</style>
