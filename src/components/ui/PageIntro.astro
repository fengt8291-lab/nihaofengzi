---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<header class="page-intro">
  <p class="page-intro__eyebrow">{eyebrow}</p>
  <h1>{title}</h1>
  {description && <p class="page-intro__description">{description}</p>}
  <div class="page-intro__content">
    <slot />
  </div>
</header>

<style>
  .page-intro {
    max-width: 52rem;
  }

  .page-intro__eyebrow {
    margin: 0;
    color: var(--color-accent);
    font-size: var(--type-eyebrow-size);
    font-weight: var(--type-eyebrow-weight);
    letter-spacing: var(--type-eyebrow-tracking);
    line-height: var(--type-eyebrow-leading);
    text-transform: uppercase;
  }

  .page-intro h1 {
    margin: var(--space-4) 0 0;
    font-size: var(--type-page-title-size);
    font-weight: var(--type-page-title-weight);
    letter-spacing: var(--type-page-title-tracking);
    line-height: var(--type-page-title-leading);
    line-break: strict;
    text-wrap: balance;
  }

  .page-intro__description {
    max-width: var(--measure-body);
    margin: var(--space-6) 0 0;
    color: var(--color-text-secondary);
    font-size: var(--type-body-large-size);
    font-weight: var(--type-body-large-weight);
    letter-spacing: var(--type-body-large-tracking);
    line-height: var(--type-body-large-leading);
    line-break: strict;
    text-wrap: pretty;
  }

  .page-intro__content {
    display: grid;
    max-width: var(--measure-body);
    gap: var(--space-4);
    margin-top: var(--space-6);
    color: var(--color-text-secondary);
    font-size: var(--type-body-size);
    font-weight: var(--type-body-weight);
    letter-spacing: var(--type-body-tracking);
    line-height: var(--type-body-leading);
    line-break: strict;
    text-wrap: pretty;
  }

  .page-intro__content:empty {
    display: none;
  }

  .page-intro__content :global(p) {
    margin: 0;
  }
</style>
