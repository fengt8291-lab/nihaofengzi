---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  tone?: 'light' | 'dark';
  class?: string;
}

const {
  eyebrow,
  title,
  description,
  tone = 'light',
  class: className,
} = Astro.props;

const hasMeta = Astro.slots.has('meta');
---

<div class:list={['section-heading', `section-heading--${tone}`, className]}>
  <div class="section-heading__main">
    <p class="section-heading__eyebrow">{eyebrow}</p>
    <h2 class="section-heading__title">{title}</h2>
    {description && <p class="section-heading__description">{description}</p>}
  </div>

  {
    hasMeta && (
      <div class="section-heading__meta">
        <slot name="meta" />
      </div>
    )
  }
</div>

<style>
  .section-heading {
    display: grid;
    gap: var(--space-5);
  }

  .section-heading__main {
    max-width: 52rem;
  }

  .section-heading__eyebrow {
    margin: 0;
    color: var(--color-accent);
    font-size: var(--type-eyebrow-size);
    font-weight: var(--type-eyebrow-weight);
    letter-spacing: var(--type-eyebrow-tracking);
    line-height: var(--type-eyebrow-leading);
    text-transform: uppercase;
  }

  .section-heading__title {
    max-width: var(--measure-section-title);
    margin: var(--space-3) 0 0;
    font-size: var(--type-section-title-size);
    font-weight: var(--type-section-title-weight);
    letter-spacing: var(--type-section-title-tracking);
    line-height: var(--type-section-title-leading);
    line-break: strict;
    text-wrap: pretty;
  }

  .section-heading__description {
    max-width: var(--measure-body-compact);
    margin: var(--space-5) 0 0;
    color: var(--color-text-secondary);
    font-size: var(--type-body-size);
    font-weight: var(--type-body-weight);
    letter-spacing: var(--type-body-tracking);
    line-height: var(--type-body-leading);
    line-break: strict;
    text-wrap: pretty;
  }

  .section-heading__meta {
    align-self: end;
    color: var(--color-text-tertiary);
    font-size: var(--type-caption-size);
    font-weight: var(--type-caption-weight);
    letter-spacing: var(--type-caption-tracking);
    line-height: var(--type-caption-leading);
  }

  .section-heading--dark .section-heading__eyebrow {
    color: rgb(245 245 247 / 58%);
  }

  .section-heading--dark .section-heading__title {
    color: var(--color-text-on-dark);
  }

  .section-heading--dark .section-heading__description,
  .section-heading--dark .section-heading__meta {
    color: rgb(245 245 247 / 66%);
  }

</style>
