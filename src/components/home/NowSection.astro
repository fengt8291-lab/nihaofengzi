---
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { getSiteContent } from '@/lib/site-content';

const home = (await getSiteContent()).home;
const updatedLabel = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'long',
}).format(new Date(`${home.now.updatedAt}T00:00:00+08:00`));
---

<Section id="now" ariaLabel="此刻">
  <Container>
    <SectionHeading
      eyebrow={home.sections.now.eyebrow}
      title={home.sections.now.title}
      description={home.sections.now.description}
    >
      <time slot="meta" datetime={home.now.updatedAt}>更新于 {updatedLabel}</time>
    </SectionHeading>

    <ol class="now-list">
      {
        home.now.items.map((item, index) => (
          <li>
            <article>
              <div class="now-list__index" aria-hidden="true">
                {String(index + 1).padStart(2, '0')}
              </div>
              <h3>{item.label}</h3>
              <p>{item.description}</p>
            </article>
          </li>
        ))
      }
    </ol>
  </Container>
</Section>

<style>
  .now-list {
    display: grid;
    padding: 0;
    margin: var(--space-8) 0 0;
    border-top: 1px solid var(--color-border-strong);
    list-style: none;
  }

  .now-list li {
    border-bottom: 1px solid var(--color-border);
  }

  .now-list article {
    display: grid;
    gap: var(--space-3);
    padding-block: var(--space-6);
  }

  .now-list__index {
    color: var(--color-growth);
    font-size: var(--type-caption-size);
    font-weight: var(--type-caption-weight);
    letter-spacing: 0.08em;
    line-height: var(--type-caption-leading);
  }

  .now-list h3,
  .now-list p {
    margin: 0;
  }

  .now-list h3 {
    font-size: var(--type-card-title-size);
    font-weight: var(--type-card-title-weight);
    letter-spacing: var(--type-card-title-tracking);
    line-height: var(--type-card-title-leading);
    line-break: strict;
    text-wrap: pretty;
  }

  .now-list p {
    max-width: 43rem;
    color: var(--color-text-secondary);
    font-size: var(--type-body-size);
    font-weight: var(--type-body-weight);
    letter-spacing: var(--type-body-tracking);
    line-height: var(--type-body-leading);
    line-break: strict;
    text-wrap: pretty;
  }

  @media (min-width: 48rem) {
    .now-list article {
      grid-template-columns: 3rem minmax(7rem, 0.45fr) minmax(0, 1.55fr);
      align-items: baseline;
      gap: var(--space-5);
    }
  }
</style>
