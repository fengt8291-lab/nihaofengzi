---
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { CURRENT_EXPLORING } from '@/data/home';

const updatedAt = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'long',
}).format(new Date(`${CURRENT_EXPLORING.updatedAt}T00:00:00+08:00`));
---

<Section id="currently-exploring" ariaLabel="Currently Exploring" tone="surface">
  <Container>
    <div class="exploring">
      <SectionHeading
        eyebrow="Now / Currently Exploring"
        title="现在，我正在关注这些问题。"
      >
        <span slot="meta">最后更新于 {updatedAt}</span>
      </SectionHeading>

      <ol class="exploring__list">
        {
          CURRENT_EXPLORING.items.map((item, index) => (
            <li class="exploring__item">
              <span class="exploring__index" aria-hidden="true">
                {String(index + 1).padStart(2, '0')}
              </span>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </Container>
</Section>

<style>
  .exploring {
    display: grid;
    gap: var(--space-8);
  }

  .exploring__list {
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .exploring__item {
    display: grid;
    gap: var(--space-3);
    padding-block: var(--space-5);
    border-top: 1px solid var(--color-border-strong);
  }

  .exploring__index {
    color: var(--color-growth);
    font-size: 0.6875rem;
    font-weight: 650;
    letter-spacing: 0.12em;
  }

  .exploring__item h3 {
    margin: 0;
    font-size: clamp(1.25rem, 3vw, 1.625rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.25;
  }

  .exploring__item p {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
    line-height: 1.75;
  }

  @media (min-width: 64rem) {
    .exploring {
      grid-template-columns: minmax(18rem, 0.78fr) minmax(0, 1.22fr);
      gap: clamp(var(--space-8), 8vw, var(--space-10));
    }

    .exploring__item {
      grid-template-columns: 2.5rem minmax(13rem, 0.82fr) minmax(16rem, 1.18fr);
      gap: var(--space-5);
      align-items: start;
      padding-block: var(--space-6);
    }
  }
</style>
