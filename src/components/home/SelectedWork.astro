---
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import WorkCard from '@/components/work/WorkCard.astro';
import { getSiteContent } from '@/lib/site-content';
import { getFeaturedWork } from '@/lib/work';

const section = (await getSiteContent()).home.sections.work;
const featuredWork = await getFeaturedWork();
---

<Section id="selected-work" ariaLabel="精选作品">
  <Container>
    <SectionHeading
      eyebrow={section.eyebrow}
      title={section.title}
      description={section.description}
    />

    <div class="selected-work__grid">
      {featuredWork.map((entry, index) => <WorkCard entry={entry} priority={index === 0} />)}
    </div>

    <div class="selected-work__action">
      <Button href={section.action.href} variant="secondary">{section.action.label}</Button>
    </div>
  </Container>
</Section>

<style>
  .selected-work__grid {
    display: grid;
    gap: var(--space-5);
    margin-top: var(--space-8);
  }

  .selected-work__action {
    margin-top: var(--space-6);
  }

  @media (min-width: 64rem) {
    .selected-work__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
