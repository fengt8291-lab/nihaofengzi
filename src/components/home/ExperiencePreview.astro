---
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { getProfileExperiences, getSiteContent } from '@/lib/site-content';

const siteContent = await getSiteContent();
const section = siteContent.home.sections.experience;
const experiences = getProfileExperiences(siteContent, siteContent.home.experienceIds);
---

<Section id="experience-preview" ariaLabel="经历摘要" tone="surface">
  <Container>
    <SectionHeading
      eyebrow={section.eyebrow}
      title={section.title}
      description={section.description}
    />

    <ol class="experience-preview">
      {
        experiences.map((experience, index) => (
          <li>
            <article>
              <div class="experience-preview__number" aria-hidden="true">
                {String(index + 1).padStart(2, '0')}
              </div>
              <div class="experience-preview__identity">
                <h3>{experience.title}</h3>
                <p>{experience.role} · {experience.period}</p>
              </div>
              <div class="experience-preview__description">
                <p>{experience.summary}</p>
                {experience.boundary && <p class="experience-preview__boundary">{experience.boundary}</p>}
              </div>
            </article>
          </li>
        ))
      }
    </ol>

    <div class="experience-preview__action">
      <Button href={section.action.href} variant="secondary">{section.action.label}</Button>
    </div>
  </Container>
</Section>

<style>
  .experience-preview {
    padding: 0;
    margin: var(--section-content-gap) 0 0;
    border-top: 1px solid var(--color-border-strong);
    list-style: none;
  }

  .experience-preview > li {
    border-bottom: 1px solid var(--color-border);
  }

  .experience-preview article {
    display: grid;
    gap: var(--space-4);
    padding-block: var(--space-6);
  }

  .experience-preview__number {
    color: var(--color-growth);
    font-size: var(--type-caption-size);
    font-weight: var(--type-caption-weight);
    line-height: var(--type-caption-leading);
  }

  .experience-preview h3,
  .experience-preview p {
    margin: 0;
  }

  .experience-preview h3 {
    font-size: var(--type-card-title-size);
    font-weight: var(--type-card-title-weight);
    letter-spacing: var(--type-card-title-tracking);
    line-height: var(--type-card-title-leading);
    line-break: strict;
    text-wrap: pretty;
  }

  .experience-preview__identity p {
    margin-top: var(--space-2);
    color: var(--color-text-tertiary);
    font-size: var(--type-meta-size);
    font-weight: var(--type-meta-weight);
    letter-spacing: var(--type-meta-tracking);
    line-height: var(--type-meta-leading);
  }

  .experience-preview__description {
    display: grid;
    gap: var(--space-3);
    color: var(--color-text-secondary);
    font-size: var(--type-body-size);
    font-weight: var(--type-body-weight);
    letter-spacing: var(--type-body-tracking);
    line-height: var(--type-body-leading);
    line-break: strict;
    text-wrap: pretty;
  }

  .experience-preview__boundary {
    color: var(--color-text-tertiary);
    font-size: var(--type-meta-size);
    font-weight: var(--type-meta-weight);
    letter-spacing: var(--type-meta-tracking);
    line-height: var(--type-meta-leading);
  }

  .experience-preview__action {
    margin-top: var(--space-6);
  }

  @media (min-width: 64rem) {
    .experience-preview article {
      grid-template-columns: 3rem minmax(14rem, 0.75fr) minmax(20rem, 1.25fr);
      gap: var(--space-6);
    }
  }
</style>
