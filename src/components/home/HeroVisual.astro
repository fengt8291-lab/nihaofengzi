---
import { getSiteContent } from '@/lib/site-content';

const [learning, research, create, practice] = (await getSiteContent()).home.hero.visualHints;
---

<div class="hero-visual" aria-hidden="true">
  <div class="hero-visual__field">
    <svg
      class="hero-visual__traces"
      viewBox="0 0 560 520"
      preserveAspectRatio="xMidYMid meet"
      focusable="false"
    >
      <path
        class="hero-visual__trace hero-visual__trace--main"
        pathLength="1"
        d="M304 28 C274 112 322 176 296 252 C270 328 317 393 286 492"
      />
      <path
        class="hero-visual__trace hero-visual__trace--one"
        pathLength="1"
        d="M72 142 C151 111 224 154 334 126 C397 110 446 128 492 108"
      />
      <path
        class="hero-visual__trace hero-visual__trace--two"
        pathLength="1"
        d="M38 280 C126 248 205 290 287 264 C370 238 420 282 524 250"
      />
      <path
        class="hero-visual__trace hero-visual__trace--three"
        pathLength="1"
        d="M118 414 C194 386 246 426 333 399 C397 379 438 402 505 382"
      />

      <circle class="hero-visual__marker hero-visual__marker--one" cx="164" cy="123" r="3" />
      <circle class="hero-visual__marker hero-visual__marker--two" cx="434" cy="267" r="3" />
    </svg>

    <span class="hero-visual__hint hero-visual__hint--learning">{learning}</span>
    <span class="hero-visual__hint hero-visual__hint--research">{research}</span>
    <span class="hero-visual__hint hero-visual__hint--create">{create}</span>
    <span class="hero-visual__hint hero-visual__hint--practice">{practice}</span>
  </div>
</div>

<style>
  .hero-visual {
    position: relative;
    width: 100%;
    max-width: 35rem;
    margin-inline: auto;
  }

  .hero-visual__field {
    position: relative;
    min-height: clamp(19rem, 54vw, 33rem);
    overflow: hidden;
    isolation: isolate;
  }

  .hero-visual__traces {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .hero-visual__trace {
    fill: none;
    stroke: var(--color-trajectory);
    stroke-width: 1.15;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    vector-effect: non-scaling-stroke;
    animation: hero-trace-in var(--duration-trace) var(--ease-emphasized) forwards;
  }

  .hero-visual__trace--main {
    stroke: var(--color-growth);
    stroke-opacity: 0.62;
  }

  .hero-visual__trace--one {
    animation-delay: 80ms;
  }

  .hero-visual__trace--two {
    animation-delay: 150ms;
  }

  .hero-visual__trace--three {
    animation-delay: 220ms;
  }

  .hero-visual__marker {
    fill: var(--color-text-secondary);
    opacity: 0;
    transform-box: fill-box;
    transform-origin: center;
    animation: hero-marker-in var(--duration-reveal) var(--ease-standard) 360ms forwards;
  }

  .hero-visual__marker--one {
    fill: var(--color-growth);
  }

  .hero-visual__marker--two {
    fill: var(--color-accent);
  }

  .hero-visual__hint {
    position: absolute;
    color: var(--color-text-tertiary);
    font-size: 0.6875rem;
    font-weight: 520;
    letter-spacing: 0.16em;
    opacity: 0;
    transform: translateY(0.35rem);
    animation: hero-hint-in var(--duration-reveal) var(--ease-standard) 320ms forwards;
  }

  .hero-visual__hint--learning {
    top: 31%;
    left: 5%;
  }

  .hero-visual__hint--research {
    top: 9%;
    right: 7%;
  }

  .hero-visual__hint--create {
    top: 61%;
    right: 6%;
  }

  .hero-visual__hint--practice {
    bottom: 3%;
    left: 24%;
  }

  @keyframes hero-trace-in {
    to {
      stroke-dashoffset: 0;
    }
  }

  @keyframes hero-marker-in {
    from {
      opacity: 0;
      transform: scale(0.6);
    }

    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes hero-hint-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (min-width: 48rem) {
    .hero-visual__field {
      min-height: clamp(27rem, 42vw, 34rem);
    }
  }

  @media (max-width: 47.999rem) {
    .hero-visual__trace {
      animation-duration: var(--duration-slow);
    }

    .hero-visual__hint,
    .hero-visual__marker {
      animation-delay: 120ms;
    }
  }
</style>
