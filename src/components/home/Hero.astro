---
import HeroVisual from '@/components/home/HeroVisual.astro';
import BrandWordmark from '@/components/ui/BrandWordmark.astro';
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import { getSiteContent } from '@/lib/site-content';

const hero = (await getSiteContent()).home.hero;
---

<Section id="hero" ariaLabel="Hero" spacing="spacious">
  <Container>
    <div class="hero">
      <div class="hero__content">
        <BrandWordmark
          variant="hero"
          english={hero.eyebrow.english}
          chinese={hero.eyebrow.chinese}
          order="chinese-first"
        />

        <h1 class="hero__title">{hero.title}</h1>
        <p class="hero__supporting-title">{hero.supportingTitle}</p>
        <p class="hero__description">{hero.introduction}</p>

        <div class="hero__actions" aria-label="首屏操作">
          <Button href={hero.actions[0].href} variant="primary">
            {hero.actions[0].label}
          </Button>
          <Button href={hero.actions[1].href} variant="secondary">
            {hero.actions[1].label}
          </Button>
        </div>
      </div>

      <div class="hero__visual">
        <HeroVisual />
      </div>
    </div>
  </Container>
</Section>

<style>
  .hero {
    display: grid;
    align-items: center;
    gap: var(--space-7);
    min-height: calc(100svh - var(--header-height) - (var(--space-9) * 2));
  }

  .hero__content {
    position: relative;
    z-index: 1;
    max-width: 45rem;
  }

  .hero__title,
  .hero__supporting-title,
  .hero__description,
  .hero__actions {
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity var(--duration-reveal) var(--ease-standard),
      transform var(--duration-reveal) var(--ease-emphasized);
  }

  .hero__supporting-title {
    max-width: 25rem;
    margin: var(--space-5) 0 0;
    color: var(--color-text-primary);
    font-size: var(--type-subtitle-size);
    font-weight: var(--type-subtitle-weight);
    letter-spacing: var(--type-subtitle-tracking);
    line-height: var(--type-subtitle-leading);
    text-wrap: pretty;
    transition-delay: 70ms;
  }

  .hero__title {
    max-width: var(--measure-display);
    margin: var(--space-5) 0 0;
    font-size: var(--type-display-size);
    font-weight: var(--type-display-weight);
    letter-spacing: var(--type-display-tracking);
    line-height: var(--type-display-leading);
    text-wrap: balance;
    transition-delay: 40ms;
  }

  .hero__description {
    max-width: 37rem;
    margin: var(--space-5) 0 0;
    color: var(--color-text-secondary);
    font-size: var(--type-body-large-size);
    font-weight: var(--type-body-large-weight);
    letter-spacing: var(--type-body-large-tracking);
    line-height: var(--type-body-large-leading);
    text-wrap: pretty;
    transition-delay: 100ms;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-6);
    transition-delay: 140ms;
  }

  .hero__visual {
    min-width: 0;
  }

  @starting-style {
    .hero__title,
    .hero__supporting-title,
    .hero__description,
    .hero__actions {
      opacity: 0;
      transform: translateY(0.75rem);
    }
  }

  @media (min-width: 48rem) {
    .hero {
      grid-template-columns: minmax(0, 1.08fr) minmax(21rem, 0.92fr);
      gap: clamp(var(--space-7), 6vw, var(--space-9));
      min-height: calc(100svh - var(--header-height) - (var(--space-10) * 2));
    }

    .hero__description {
      margin-top: var(--space-6);
    }
  }

  @media (max-width: 47.999rem) {
    .hero__visual {
      width: min(100%, 30rem);
      margin-inline: auto;
    }
  }
</style>
