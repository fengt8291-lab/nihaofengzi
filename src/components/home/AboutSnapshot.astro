---
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { ABOUT_SNAPSHOT } from '@/data/home';
---

<Section id="about-snapshot" ariaLabel="About Snapshot">
  <Container>
    <div class="about">
      <div
        class="about__portrait"
        role="img"
        aria-label="个人照片占位，待添加经本人确认的真实照片"
      >
        <span class="about__portrait-label">Portrait / 待补充</span>
      </div>

      <div class="about__content">
        <SectionHeading eyebrow="About" title={ABOUT_SNAPSHOT.title} />
        <p class="about__description">{ABOUT_SNAPSHOT.description}</p>
        <p class="about__note">{ABOUT_SNAPSHOT.note}</p>
      </div>
    </div>
  </Container>
</Section>

<style>
  .about {
    display: grid;
    align-items: center;
    gap: var(--space-8);
  }

  .about__portrait {
    position: relative;
    display: flex;
    width: 100%;
    aspect-ratio: 4 / 5;
    align-items: flex-end;
    overflow: hidden;
    padding: var(--space-5);
    border-radius: var(--radius-md);
    background: var(--color-portrait-background);
  }

  .about__portrait-label {
    color: var(--color-text-tertiary);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .about__content {
    max-width: 42rem;
  }

  .about__description {
    margin: var(--space-6) 0 0;
    color: var(--color-text-secondary);
    font-size: clamp(1.0625rem, 2.5vw, 1.25rem);
    line-height: 1.75;
  }

  .about__note {
    max-width: 35rem;
    padding-top: var(--space-5);
    margin: var(--space-5) 0 0;
    border-top: 1px solid var(--color-border-strong);
    color: var(--color-text-tertiary);
    font-size: 0.875rem;
    line-height: 1.7;
  }

  @media (min-width: 48rem) {
    .about {
      grid-template-columns: minmax(18rem, 0.78fr) minmax(0, 1.22fr);
      gap: clamp(var(--space-8), 8vw, var(--space-10));
    }
  }
</style>
