---
import { getCollection, render } from 'astro:content';

import ProjectCard from '@/components/projects/ProjectCard.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';

const projects = (await getCollection('projects', ({ data }) => data.featured && !data.draft))
  .sort((a, b) => a.data.order - b.data.order);

const renderedProjects = await Promise.all(
  projects.map(async (project) => ({
    project,
    rendered: await render(project),
  })),
);
---

<Section id="selected-projects" ariaLabel="Selected Projects">
  <Container>
    <SectionHeading
      eyebrow="Selected Projects"
      title="把思考放进真实项目里。"
      description="这些项目仍在不同阶段生长。这里记录问题、判断和实践，不包装尚未发生的结果。"
    />

    <div class="projects__grid">
      {
        renderedProjects.map(({ project, rendered: { Content } }, index) => (
          <div class:list={['projects__item', { 'projects__item--featured': index === 0 }]}>
            <ProjectCard project={project.data} index={index + 1} featured={index === 0}>
              <Content />
            </ProjectCard>
          </div>
        ))
      }
    </div>
  </Container>
</Section>

<style>
  .projects__grid {
    display: grid;
    gap: var(--space-5);
    margin-top: var(--space-8);
  }

  .projects__item {
    min-width: 0;
  }

  .projects__item :global(.card) {
    height: 100%;
  }

  @media (min-width: 48rem) {
    .projects__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-6);
    }

    .projects__item--featured {
      grid-column: 1 / -1;
    }
  }
</style>
