---
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { RESEARCH_DIRECTIONS } from '@/data/home';
---

<Section id="research-preview" ariaLabel="Research Preview" tone="surface">
  <Container>
    <SectionHeading
      eyebrow="Research & Thinking"
      title="从实践出发，也持续理解问题。"
    />

    <div class="research__list">
      {
        RESEARCH_DIRECTIONS.map((direction, index) => (
          <article class="research__item">
            <span class="research__index" aria-hidden="true">
              {String(index + 1).padStart(2, '0')}
            </span>
            <h3>{direction.title}</h3>
            <p>{direction.description}</p>
            <span class="research__status">
              <span aria-hidden="true"></span>
              持续研究中
            </span>
          </article>
        ))
      }
    </div>
  </Container>
</Section>

<style>
  .research__list {
    margin-top: var(--space-8);
    border-bottom: 1px solid var(--color-border-strong);
  }

  .research__item {
    display: grid;
    gap: var(--space-3);
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-border-strong);
  }

  .research__index {
    color: var(--color-text-tertiary);
    font-size: 0.6875rem;
    font-weight: 650;
    letter-spacing: 0.12em;
  }

  .research__item h3 {
    margin: 0;
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.18;
  }

  .research__item p {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
    line-height: 1.75;
  }

  .research__status {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-growth);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .research__status span {
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 50%;
    background: currentColor;
  }

  @media (min-width: 64rem) {
    .research__item {
      grid-template-columns: 2.5rem minmax(15rem, 0.8fr) minmax(22rem, 1.2fr) auto;
      gap: var(--space-5);
      align-items: start;
      padding-block: var(--space-7);
    }

    .research__status {
      justify-self: end;
      padding-top: 0.45rem;
    }
  }
</style>
