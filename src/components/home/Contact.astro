---
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { CONTACT_CONTENT } from '@/data/home';
---

<Section id="contact" ariaLabel="Contact" spacing="compact" tone="dark">
  <Container>
    <div class="contact">
      <SectionHeading eyebrow="Contact" title={CONTACT_CONTENT.title} tone="dark" />

      <div class="contact__content">
        <p>{CONTACT_CONTENT.description}</p>
        <p class="contact__status" aria-label="联系入口暂未开放">
          <span aria-hidden="true"></span>
          {CONTACT_CONTENT.placeholder}
        </p>
      </div>
    </div>
  </Container>
</Section>

<style>
  .contact {
    display: grid;
    gap: var(--space-7);
  }

  .contact__content {
    align-self: end;
  }

  .contact__content > p:first-child {
    max-width: 34rem;
    margin: 0;
    color: rgb(245 245 247 / 68%);
    font-size: 1rem;
    line-height: 1.75;
  }

  .contact__status {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    margin: var(--space-5) 0 0;
    color: rgb(245 245 247 / 48%);
    font-size: 0.8125rem;
    font-weight: 600;
  }

  .contact__status span {
    width: 1.75rem;
    height: 1px;
    background: rgb(245 245 247 / 28%);
  }

  @media (min-width: 48rem) {
    .contact {
      grid-template-columns: minmax(0, 1fr) minmax(20rem, 0.72fr);
      gap: var(--space-9);
    }
  }
</style>
