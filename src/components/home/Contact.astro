---
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { getSiteContent } from '@/lib/site-content';

const siteContent = await getSiteContent();
const contact = siteContent.home.sections.contact;
const profileContact = siteContent.identity.contact;
---

<Section id="contact" ariaLabel="Contact" spacing="compact" tone="dark">
  <Container>
    <div class="contact">
      <SectionHeading
        eyebrow={contact.eyebrow}
        title={contact.title}
        tone="dark"
      />

      <div class="contact__content">
        <p>{contact.description}</p>
        <ul class="contact__links">
          <li>
            <a href={`mailto:${profileContact.email}`}>
              <span>Email</span>
              <strong>{profileContact.email}</strong>
            </a>
          </li>
          <li>
            <a href={profileContact.github.url} target="_blank" rel="noreferrer">
              <span>GitHub</span>
              <strong>{profileContact.github.username} ↗</strong>
            </a>
          </li>
          <li>
            <a href={contact.resumeAction.href}>
              <span>Resume</span>
              <strong>{contact.resumeAction.label}</strong>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </Container>
</Section>

<style>
  .contact {
    display: grid;
    gap: var(--space-7);
  }

  .contact__content {
    align-self: end;
  }

  .contact__content > p:first-child {
    max-width: 34rem;
    margin: 0;
    color: rgb(245 245 247 / 68%);
    font-size: 1rem;
    line-height: 1.75;
  }

  .contact__links {
    display: grid;
    padding: 0;
    margin: var(--space-6) 0 0;
    border-top: 1px solid rgb(245 245 247 / 16%);
    list-style: none;
  }

  .contact__links li {
    border-bottom: 1px solid rgb(245 245 247 / 16%);
  }

  .contact__links a {
    display: flex;
    min-height: 3.5rem;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    color: var(--color-text-on-dark);
    font-size: 0.875rem;
    text-decoration: none;
  }

  .contact__links span {
    color: rgb(245 245 247 / 48%);
  }

  .contact__links strong {
    overflow-wrap: anywhere;
    font-weight: 560;
    text-align: right;
  }

  .contact__links a:hover strong {
    color: rgb(245 245 247 / 72%);
  }

  @media (min-width: 48rem) {
    .contact {
      grid-template-columns: minmax(0, 1fr) minmax(20rem, 0.72fr);
      gap: var(--space-9);
    }
  }
</style>
