---
import BaseLayout from '@/layouts/BaseLayout.astro';

import EducationSummary from '@/components/profile/EducationSummary.astro';
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import PageIntro from '@/components/ui/PageIntro.astro';
import Section from '@/components/ui/Section.astro';
import { PROFILE } from '@/data/profile';
import { SITE } from '@/data/site';
import { getCanonicalUrl } from '@/lib/paths';

const canonical = getCanonicalUrl(Astro.url.pathname, SITE.url);
---

<BaseLayout
  title="关于田丰"
  description="了解田丰的教育背景、大学阶段的方向调整，以及他如何在管理、技术与真实生活之间持续学习和实践。"
  canonical={canonical}
>
  <main id="main-content">
    <Section spacing="spacious">
      <Container>
        <PageIntro eyebrow="About / 关于" title="关于田丰">
          {PROFILE.about.introduction.map((paragraph) => <p>{paragraph}</p>)}
        </PageIntro>
      </Container>
    </Section>

    <Section tone="surface">
      <Container>
        <div class="about-page__section">
          <header>
            <p>Education / 教育</p>
            <h2>当前的学习背景</h2>
          </header>
          <EducationSummary />
        </div>
      </Container>
    </Section>

    <Section>
      <Container>
        <div class="about-page__editorial">
          <header>
            <p>Why / 为什么</p>
            <h2>把管理、技术与真实生活连接起来。</h2>
          </header>
          <div class="about-page__prose">
            {PROFILE.about.focus.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </div>
      </Container>
    </Section>

    <Section tone="surface">
      <Container>
        <div class="about-page__section">
          <header>
            <p>Path / 经历变化</p>
            <h2>在尝试中修正方向。</h2>
          </header>
          <ol class="about-page__turning-points">
            {
              PROFILE.about.turningPoints.map((item, index) => (
                <li>
                  <article>
                    <p class="about-page__index">{String(index + 1).padStart(2, '0')}</p>
                    <h3>{item.title}</h3>
                    {'period' in item && item.period && <p class="about-page__period">{item.period}</p>}
                    <p>{item.description}</p>
                  </article>
                </li>
              ))
            }
          </ol>
        </div>
      </Container>
    </Section>

    <Section>
      <Container>
        <div class="about-page__editorial">
          <header>
            <p>Current / 当前</p>
            <h2>仍在建立自己的能力结构。</h2>
          </header>
          <div class="about-page__prose">
            {PROFILE.about.current.map((paragraph) => <p>{paragraph}</p>)}
            <nav class="about-page__links" aria-label="继续了解田丰">
              <Button href="/experience/" variant="secondary">查看经历</Button>
              <Button href="/work/" variant="secondary">查看作品</Button>
              <Button href="/resume/" variant="text">查看简历</Button>
            </nav>
          </div>
        </div>
      </Container>
    </Section>
  </main>
</BaseLayout>

<style>
  .about-page__section,
  .about-page__editorial {
    display: grid;
    gap: var(--space-7);
  }

  .about-page__section > header > p,
  .about-page__editorial > header > p {
    margin: 0;
    color: var(--color-accent);
    font-size: 0.75rem;
    font-weight: 650;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .about-page__section h2,
  .about-page__editorial h2 {
    max-width: 14ch;
    margin: var(--space-3) 0 0;
    font-size: clamp(2.25rem, 5vw, 4rem);
    font-weight: 620;
    letter-spacing: -0.05em;
    line-height: 1.12;
  }

  .about-page__prose {
    display: grid;
    max-width: 44rem;
    gap: var(--space-4);
    color: var(--color-text-secondary);
    line-height: 1.85;
  }

  .about-page__prose p {
    margin: 0;
  }

  .about-page__turning-points {
    display: grid;
    gap: var(--space-5);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .about-page__turning-points article {
    height: 100%;
    padding: var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-card-background);
  }

  .about-page__turning-points h3 {
    margin: var(--space-5) 0 0;
    font-size: 1.5rem;
    font-weight: 620;
    letter-spacing: -0.035em;
  }

  .about-page__turning-points article > p:last-child {
    margin: var(--space-5) 0 0;
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  .about-page__index,
  .about-page__period {
    margin: 0;
    color: var(--color-text-tertiary);
    font-size: 0.75rem;
  }

  .about-page__period {
    margin-top: var(--space-2);
  }

  .about-page__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  @media (min-width: 64rem) {
    .about-page__editorial {
      grid-template-columns: minmax(15rem, 0.75fr) minmax(0, 1.25fr);
      gap: var(--space-9);
    }

    .about-page__turning-points {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
