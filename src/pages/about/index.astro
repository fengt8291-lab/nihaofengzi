---
import BaseLayout from '@/layouts/BaseLayout.astro';

import EducationSummary from '@/components/profile/EducationSummary.astro';
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import PageIntro from '@/components/ui/PageIntro.astro';
import Section from '@/components/ui/Section.astro';
import { getCanonicalUrl } from '@/lib/paths';
import { getSiteContent } from '@/lib/site-content';

const siteContent = await getSiteContent();
const page = siteContent.pages.about;
const profileAbout = siteContent.profile.about;
const canonical = getCanonicalUrl(Astro.url.pathname, siteContent.global.url);
---

<BaseLayout
  title={page.seo.title}
  description={page.seo.description}
  canonical={canonical}
>
  <main id="main-content">
    <Section spacing="spacious">
      <Container>
        <PageIntro eyebrow={page.intro.eyebrow} title={page.intro.title}>
          {profileAbout.introduction.map((paragraph) => <p>{paragraph}</p>)}
        </PageIntro>
      </Container>
    </Section>

    <Section tone="surface">
      <Container>
        <div class="about-page__section">
          <header>
            <p>{page.education.eyebrow}</p>
            <h2>{page.education.title}</h2>
          </header>
          <EducationSummary />
        </div>
      </Container>
    </Section>

    <Section>
      <Container>
        <div class="about-page__editorial">
          <header>
            <p>{page.why.eyebrow}</p>
            <h2>{page.why.title}</h2>
          </header>
          <div class="about-page__prose">
            {profileAbout.focus.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </div>
      </Container>
    </Section>

    <Section tone="surface">
      <Container>
        <div class="about-page__section">
          <header>
            <p>{page.path.eyebrow}</p>
            <h2>{page.path.title}</h2>
          </header>
          <ol class="about-page__turning-points">
            {
              profileAbout.turningPoints.map((item, index) => (
                <li>
                  <article>
                    <p class="about-page__index">{String(index + 1).padStart(2, '0')}</p>
                    <h3>{item.title}</h3>
                    {'period' in item && item.period && <p class="about-page__period">{item.period}</p>}
                    <p>{item.description}</p>
                  </article>
                </li>
              ))
            }
          </ol>
        </div>
      </Container>
    </Section>

    <Section>
      <Container>
        <div class="about-page__editorial">
          <header>
            <p>{page.current.eyebrow}</p>
            <h2>{page.current.title}</h2>
          </header>
          <div class="about-page__prose">
            {profileAbout.current.map((paragraph) => <p>{paragraph}</p>)}
            <nav class="about-page__links" aria-label={`继续了解${siteContent.identity.name.chinese}`}>
              <Button href={page.actions[0].href} variant="secondary">{page.actions[0].label}</Button>
              <Button href={page.actions[1].href} variant="secondary">{page.actions[1].label}</Button>
              <Button href={page.actions[2].href} variant="text">{page.actions[2].label}</Button>
            </nav>
          </div>
        </div>
      </Container>
    </Section>
  </main>
</BaseLayout>

<style>
  .about-page__section,
  .about-page__editorial {
    display: grid;
    gap: var(--space-7);
  }

  .about-page__section > header > p,
  .about-page__editorial > header > p {
    margin: 0;
    color: var(--color-accent);
    font-size: 0.75rem;
    font-weight: 650;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .about-page__section h2,
  .about-page__editorial h2 {
    max-width: 14ch;
    margin: var(--space-3) 0 0;
    font-size: clamp(2.25rem, 5vw, 4rem);
    font-weight: 620;
    letter-spacing: -0.05em;
    line-height: 1.12;
  }

  .about-page__prose {
    display: grid;
    max-width: 44rem;
    gap: var(--space-4);
    color: var(--color-text-secondary);
    line-height: 1.85;
  }

  .about-page__prose p {
    margin: 0;
  }

  .about-page__turning-points {
    display: grid;
    gap: var(--space-5);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .about-page__turning-points article {
    height: 100%;
    padding: var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-card-background);
  }

  .about-page__turning-points h3 {
    margin: var(--space-5) 0 0;
    font-size: 1.5rem;
    font-weight: 620;
    letter-spacing: -0.035em;
  }

  .about-page__turning-points article > p:last-child {
    margin: var(--space-5) 0 0;
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  .about-page__index,
  .about-page__period {
    margin: 0;
    color: var(--color-text-tertiary);
    font-size: 0.75rem;
  }

  .about-page__period {
    margin-top: var(--space-2);
  }

  .about-page__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  @media (min-width: 64rem) {
    .about-page__editorial {
      grid-template-columns: minmax(15rem, 0.75fr) minmax(0, 1.25fr);
      gap: var(--space-9);
    }

    .about-page__turning-points {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
