---
import BaseLayout from '@/layouts/BaseLayout.astro';

import ExperienceList from '@/components/profile/ExperienceList.astro';
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import PageIntro from '@/components/ui/PageIntro.astro';
import Section from '@/components/ui/Section.astro';
import { getCanonicalUrl } from '@/lib/paths';
import { getSiteContent } from '@/lib/site-content';

const siteContent = await getSiteContent();
const page = siteContent.pages.experience;
const canonical = getCanonicalUrl(Astro.url.pathname, siteContent.global.url);
---

<BaseLayout
  title={page.seo.title}
  description={page.seo.description}
  canonical={canonical}
>
  <main id="main-content">
    <Section spacing="spacious">
      <Container>
        <PageIntro
          eyebrow={page.intro.eyebrow}
          title={page.intro.title}
          description={page.intro.description}
        />
      </Container>
    </Section>

    {
      page.groups.map((group, index) => {
        const experiences = siteContent.profile.experiences.filter(
          (entry) => entry.category === group.category,
        );

        return (
          <Section tone={index % 2 === 0 ? 'surface' : 'default'}>
            <Container>
              <div class="experience-page__group">
                <header>
                  <p>{group.eyebrow}</p>
                  <h2>{group.title}</h2>
                  <p class="experience-page__description">{group.description}</p>
                </header>
                <ExperienceList experiences={experiences} />
              </div>
            </Container>
          </Section>
        );
      })
    }

    <Section spacing="compact">
      <Container>
        <div class="experience-page__next">
          <p>{page.footer.description}</p>
          <div>
            <Button href={page.footer.actions[0].href} variant="secondary">
              {page.footer.actions[0].label}
            </Button>
            <Button href={page.footer.actions[1].href} variant="text">
              {page.footer.actions[1].label}
            </Button>
          </div>
        </div>
      </Container>
    </Section>
  </main>
</BaseLayout>

<style>
  .experience-page__group {
    display: grid;
    gap: var(--space-7);
  }

  .experience-page__group > header > p:first-child {
    margin: 0;
    color: var(--color-accent);
    font-size: var(--type-eyebrow-size);
    font-weight: var(--type-eyebrow-weight);
    letter-spacing: var(--type-eyebrow-tracking);
    line-height: var(--type-eyebrow-leading);
    text-transform: uppercase;
  }

  .experience-page__group h2 {
    margin: var(--space-3) 0 0;
    font-size: var(--type-section-title-size);
    font-weight: var(--type-section-title-weight);
    letter-spacing: var(--type-section-title-tracking);
    line-height: var(--type-section-title-leading);
    line-break: strict;
    text-wrap: pretty;
  }

  .experience-page__description {
    max-width: 34rem;
    margin: var(--space-4) 0 0;
    color: var(--color-text-secondary);
    font-size: var(--type-body-size);
    font-weight: var(--type-body-weight);
    letter-spacing: var(--type-body-tracking);
    line-height: var(--type-body-leading);
    line-break: strict;
    text-wrap: pretty;
  }

  .experience-page__next {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
  }

  .experience-page__next p {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--type-body-size);
    line-height: var(--type-body-leading);
    line-break: strict;
    text-wrap: pretty;
  }

  .experience-page__next > div {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  @media (min-width: 64rem) {
    .experience-page__group {
      grid-template-columns: minmax(15rem, 0.68fr) minmax(0, 1.32fr);
      gap: var(--space-9);
    }
  }
</style>
