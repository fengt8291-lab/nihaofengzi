---
import BaseLayout from '@/layouts/BaseLayout.astro';

import ExperienceList from '@/components/profile/ExperienceList.astro';
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import PageIntro from '@/components/ui/PageIntro.astro';
import Section from '@/components/ui/Section.astro';
import { PROFILE, type ExperienceCategory } from '@/data/profile';
import { SITE } from '@/data/site';
import { getCanonicalUrl } from '@/lib/paths';

const canonical = getCanonicalUrl(Astro.url.pathname, SITE.url);
const groups: readonly { category: ExperienceCategory; eyebrow: string; title: string; description: string }[] = [
  {
    category: 'campus',
    eyebrow: 'Campus / 校园',
    title: '校园组织与公共事务',
    description: '在长期的信息协调、活动支持和公共事务中，练习准确、回应与协作。',
  },
  {
    category: 'work',
    eyebrow: 'Work / 工作',
    title: '门店与现实工作',
    description: '在顾客、商品、陈列和日常流程中理解稳定执行的价值。',
  },
  {
    category: 'research',
    eyebrow: 'Research support / 资料整理',
    title: '研究与资料整理',
    description: '通过公开材料检索、数据摘录和文字校对，建立对准确性的具体认识。',
  },
];
---

<BaseLayout
  title="经历"
  description="田丰在校园组织、班级公共事务、无印良品门店工作和 ESG 报告资料整理中的真实经历。"
  canonical={canonical}
>
  <main id="main-content">
    <Section spacing="spacious">
      <Container>
        <PageIntro
          eyebrow="Experience / 经历"
          title="经历"
          description="我的能力不只来自个人项目，也来自校园组织、公共事务、研究整理和真实工作流程。"
        />
      </Container>
    </Section>

    {
      groups.map((group, index) => {
        const experiences = PROFILE.experiences.filter((entry) => entry.category === group.category);

        return (
          <Section tone={index % 2 === 0 ? 'surface' : 'default'}>
            <Container>
              <div class="experience-page__group">
                <header>
                  <p>{group.eyebrow}</p>
                  <h2>{group.title}</h2>
                  <p class="experience-page__description">{group.description}</p>
                </header>
                <ExperienceList experiences={experiences} />
              </div>
            </Container>
          </Section>
        );
      })
    }

    <Section spacing="compact">
      <Container>
        <div class="experience-page__next">
          <p>这些经历与作品共同构成我当前的能力证据。</p>
          <div>
            <Button href="/work/" variant="secondary">查看作品</Button>
            <Button href="/resume/" variant="text">查看简历</Button>
          </div>
        </div>
      </Container>
    </Section>
  </main>
</BaseLayout>

<style>
  .experience-page__group {
    display: grid;
    gap: var(--space-7);
  }

  .experience-page__group > header > p:first-child {
    margin: 0;
    color: var(--color-accent);
    font-size: 0.75rem;
    font-weight: 650;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .experience-page__group h2 {
    margin: var(--space-3) 0 0;
    font-size: clamp(2.25rem, 5vw, 4rem);
    font-weight: 620;
    letter-spacing: -0.05em;
    line-height: 1.12;
  }

  .experience-page__description {
    max-width: 34rem;
    margin: var(--space-4) 0 0;
    color: var(--color-text-secondary);
    line-height: 1.75;
  }

  .experience-page__next {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
  }

  .experience-page__next p {
    margin: 0;
    color: var(--color-text-secondary);
  }

  .experience-page__next > div {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  @media (min-width: 64rem) {
    .experience-page__group {
      grid-template-columns: minmax(15rem, 0.68fr) minmax(0, 1.32fr);
      gap: var(--space-9);
    }
  }
</style>
