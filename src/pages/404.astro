---
import BaseLayout from '@/layouts/BaseLayout.astro';

import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
---

<BaseLayout
  title="页面未找到"
  description="你访问的页面不存在或已移动。"
  canonical={null}
  noIndex
>
  <main id="main-content">
    <Section spacing="spacious">
      <Container size="narrow">
        <div class="not-found">
          <p class="not-found__code">404</p>
          <h1>页面未找到</h1>
          <p>你访问的页面不存在或已移动。</p>
          <nav aria-label="继续浏览">
            <Button href="/">返回首页</Button>
            <Button href="/work/" variant="secondary">查看作品</Button>
          </nav>
        </div>
      </Container>
    </Section>
  </main>
</BaseLayout>

<style>
  .not-found {
    max-width: var(--measure-body-compact);
  }

  .not-found__code {
    margin: 0;
    color: var(--color-accent);
    font-size: var(--type-eyebrow-size);
    font-weight: var(--type-eyebrow-weight);
    letter-spacing: var(--type-eyebrow-tracking);
    line-height: var(--type-eyebrow-leading);
  }

  .not-found h1 {
    margin: var(--space-4) 0 0;
    font-size: var(--type-page-title-size);
    font-weight: var(--type-page-title-weight);
    letter-spacing: var(--type-page-title-tracking);
    line-height: var(--type-page-title-leading);
    text-wrap: balance;
  }

  .not-found > p:not(.not-found__code) {
    margin: var(--space-6) 0 0;
    color: var(--color-text-secondary);
    font-size: var(--type-body-large-size);
    line-height: var(--type-body-large-leading);
  }

  .not-found nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-7);
  }
</style>
