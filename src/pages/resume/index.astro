---
import BaseLayout from '@/layouts/BaseLayout.astro';

import EducationSummary from '@/components/profile/EducationSummary.astro';
import ExperienceList from '@/components/profile/ExperienceList.astro';
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import PageIntro from '@/components/ui/PageIntro.astro';
import Section from '@/components/ui/Section.astro';
import { getCanonicalUrl } from '@/lib/paths';
import { getSiteContent } from '@/lib/site-content';
import { getFeaturedWork, getWorkHref } from '@/lib/work';

const siteContent = await getSiteContent();
const page = siteContent.pages.resume;
const identity = siteContent.identity;
const canonical = getCanonicalUrl(Astro.url.pathname, siteContent.global.url);
const experiences = siteContent.profile.experiences.filter((entry) => entry.resume);
const featuredWork = await getFeaturedWork();
---

<BaseLayout
  title={page.seo.title}
  description={page.seo.description}
  canonical={canonical}
>
  <main id="main-content" class="resume-page">
    <Section spacing="spacious">
      <Container>
        <PageIntro eyebrow={page.intro.eyebrow} title={identity.name.chinese} description={identity.summary} />
        <div class="resume-page__identity">
          <span>{identity.name.english}</span>
          <span>{identity.location}</span>
          <a href={`mailto:${identity.contact.email}`}>{identity.contact.email}</a>
          <a href={identity.contact.github.url} target="_blank" rel="noreferrer">
            GitHub · {identity.contact.github.username}<span class="sr-only">（在新窗口打开）</span>
          </a>
        </div>
      </Container>
    </Section>

    <Section tone="surface">
      <Container>
        <div class="resume-page__section">
          <h2>{page.sections.education}</h2>
          <EducationSummary />
        </div>
      </Container>
    </Section>

    <Section>
      <Container>
        <div class="resume-page__section">
          <h2>{page.sections.experience}</h2>
          <ExperienceList experiences={experiences} compact />
        </div>
      </Container>
    </Section>

    <Section tone="surface">
      <Container>
        <div class="resume-page__section">
          <h2>{page.sections.work}</h2>
          <ol class="resume-page__work">
            {
              featuredWork.map((entry) => (
                <li>
                  <article>
                    <div>
                      <p>{entry.data.type}</p>
                      <h3>{entry.data.title}</h3>
                    </div>
                    <p>{entry.data.summary}</p>
                    <dl>
                      <div>
                        <dt>我的角色</dt>
                        <dd>{entry.data.role}</dd>
                      </div>
                      <div>
                        <dt>状态</dt>
                        <dd>{entry.data.status}</dd>
                      </div>
                    </dl>
                    {getWorkHref(entry) && <a href={getWorkHref(entry)}>查看项目 →</a>}
                  </article>
                </li>
              ))
            }
          </ol>
        </div>
      </Container>
    </Section>

    <Section>
      <Container>
        <div class="resume-page__section">
          <h2>{page.sections.capabilities}</h2>
          <ul class="resume-page__capabilities">
            {
              siteContent.profile.capabilities.map((capability) => (
                <li>
                  <h3>{capability.title}</h3>
                  <p>{capability.description}</p>
                  <p class="resume-page__evidence">相关证据：{capability.evidence.join('、')}</p>
                </li>
              ))
            }
          </ul>
        </div>
      </Container>
    </Section>

    <Section spacing="compact" tone="dark">
      <Container>
        <div class="resume-page__contact">
          <div>
            <p>{page.contact.eyebrow}</p>
            <h2>{page.contact.title}</h2>
          </div>
          <div>
            <Button href={`mailto:${identity.contact.email}`} variant="secondary">
              {page.contact.emailActionLabel}
            </Button>
            <Button href={identity.contact.github.url} target="_blank" rel="noreferrer" variant="text">
              {page.contact.githubActionLabel}
            </Button>
          </div>
        </div>
      </Container>
    </Section>
  </main>
</BaseLayout>

<style>
  .resume-page__identity {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-5);
    margin-top: var(--space-6);
    color: var(--color-text-secondary);
    font-size: var(--type-meta-size);
    font-weight: var(--type-meta-weight);
    letter-spacing: var(--type-meta-tracking);
    line-height: var(--type-meta-leading);
  }

  .resume-page__identity a {
    color: var(--color-accent);
    overflow-wrap: anywhere;
    text-decoration: none;
  }

  .resume-page__section {
    display: grid;
    gap: var(--space-7);
  }

  .resume-page__section > h2,
  .resume-page__contact h2 {
    margin: 0;
    font-size: var(--type-section-title-size);
    font-weight: var(--type-section-title-weight);
    letter-spacing: var(--type-section-title-tracking);
    line-height: var(--type-section-title-leading);
    line-break: strict;
    text-wrap: pretty;
  }

  .resume-page__work,
  .resume-page__capabilities {
    display: grid;
    gap: var(--space-5);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .resume-page__work article,
  .resume-page__capabilities li {
    height: 100%;
    padding: var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-card-background);
  }

  .resume-page__work article > div:first-child > p {
    margin: 0;
    color: var(--color-growth);
    font-size: var(--type-caption-size);
    font-weight: var(--type-caption-weight);
    line-height: var(--type-caption-leading);
  }

  .resume-page__work h3,
  .resume-page__capabilities h3 {
    margin: var(--space-3) 0 0;
    font-size: var(--type-card-title-size);
    font-weight: var(--type-card-title-weight);
    letter-spacing: var(--type-card-title-tracking);
    line-height: var(--type-card-title-leading);
    line-break: strict;
    text-wrap: pretty;
  }

  .resume-page__work article > p,
  .resume-page__capabilities p {
    margin: var(--space-4) 0 0;
    color: var(--color-text-secondary);
    font-size: var(--type-body-size);
    line-height: var(--type-body-leading);
    line-break: strict;
    text-wrap: pretty;
  }

  .resume-page__work dl {
    display: grid;
    gap: var(--space-3);
    padding-top: var(--space-5);
    margin: var(--space-5) 0 0;
    border-top: 1px solid var(--color-border);
  }

  .resume-page__work dt {
    color: var(--color-text-tertiary);
    font-size: var(--type-caption-size);
    font-weight: var(--type-caption-weight);
    line-height: var(--type-caption-leading);
  }

  .resume-page__work dd {
    margin: var(--space-1) 0 0;
    color: var(--color-text-secondary);
    font-size: var(--type-meta-size);
    font-weight: var(--type-meta-weight);
    letter-spacing: var(--type-meta-tracking);
    line-height: var(--type-meta-leading);
    line-break: strict;
    text-wrap: pretty;
  }

  .resume-page__work a {
    display: inline-flex;
    margin-top: var(--space-5);
    color: var(--color-accent);
    font-weight: 600;
    text-decoration: none;
  }

  .resume-page__evidence {
    color: var(--color-text-tertiary) !important;
    font-size: var(--type-meta-size);
    line-height: var(--type-meta-leading);
  }

  .resume-page__contact {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-6);
  }

  .resume-page__contact > div:first-child > p {
    margin: 0 0 var(--space-3);
    color: rgb(245 245 247 / 58%);
    font-size: var(--type-eyebrow-size);
    font-weight: var(--type-eyebrow-weight);
    letter-spacing: var(--type-eyebrow-tracking);
    line-height: var(--type-eyebrow-leading);
    text-transform: uppercase;
  }

  .resume-page__contact h2 {
    color: var(--color-text-on-dark);
  }

  .resume-page__contact > div:last-child {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  @media (min-width: 48rem) {
    .resume-page__work,
    .resume-page__capabilities {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 64rem) {
    .resume-page__work {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
