---
import '@/styles/global.css';

import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import SEOHead from '@/components/layout/SEOHead.astro';
import { getCanonicalUrl } from '@/lib/paths';
import { getSiteContent } from '@/lib/site-content';
import type { SeoMetadata } from '@/types/site';

interface Props extends SeoMetadata {
  lang?: string;
}

const siteContent = await getSiteContent();
const site = siteContent.global;
const {
  title = site.defaultTitle,
  description = site.defaultDescription,
  canonical = getCanonicalUrl(Astro.url.pathname, site.url),
  image,
  noIndex = false,
  lang = site.language,
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <SEOHead
      title={title}
      description={description}
      canonical={canonical}
      image={image}
      noIndex={noIndex}
    />
  </head>
  <body>
    <a class="skip-link" href="#main-content">跳到主要内容</a>
    <Header />
    <slot />
    <Footer />
  </body>
</html>

<style is:global>
  .skip-link {
    position: fixed;
    top: var(--space-3);
    left: var(--space-3);
    z-index: calc(var(--layer-header) + 1);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-pill);
    background: var(--color-dark-background);
    color: var(--color-text-on-dark);
    text-decoration: none;
    transform: translateY(calc(-100% - var(--space-5)));
  }

  .skip-link:focus {
    transform: translateY(0);
  }
</style>
